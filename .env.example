# Firecrawl API key — used only by scripts/scrape.mjs, never in the site bundle.
FIRECRAWL_API_KEY=

# Deploy target. Defaults assume GitHub Pages user-site.
# Override for local previews or custom domain.
SITE_URL=https://example.github.io
SITE_BASE=/inpro

# Feedback channel routing — both PUBLIC_*, shipped in bundle.
# At least ONE of PUBLIC_REPO_URL or PUBLIC_FEEDBACK_EMAIL MUST be set in any
# environment that builds the site (CI, local). The build throws otherwise.
# When PUBLIC_REPO_URL is set, FeedbackLink uses GitHub Issue prefills (preferred).
# Otherwise it falls back to a mailto pointing at PUBLIC_FEEDBACK_EMAIL.
# If both are set, GitHub Issues is primary; mailto is the secondary "no GitHub account" path.
# For PUBLIC_FEEDBACK_EMAIL, use a project-only forwarding address — never a personal inbox.
PUBLIC_REPO_URL=
PUBLIC_FEEDBACK_EMAIL=
