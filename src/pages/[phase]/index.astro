---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { PHASE_LABEL, TOPIC_LABEL, PHASES, type Phase } from '../../lib/tags';

export async function getStaticPaths() {
  return PHASES.map(phase => ({ params: { phase } }));
}

const { phase } = Astro.params as { phase: Phase };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('published', e => e.data.phase === phase);
const sorted = all.sort((a, b) => (a.data.order - b.data.order) || a.data.title.localeCompare(b.data.title));

const phaseDescription: Record<Phase, string> = {
  before: 'Everything that has to happen before you leave CONUS — orders, EFMP, sponsor contact, passports, pets, POV prep.',
  arrive: 'Your first two weeks in Wiesbaden: lodging, ID enrollment, housing office, finance office, vehicle paperwork.',
  settle: '30 / 60 / 90-day tasks: Anmeldung, SOFA stamp, schools, healthcare enrollment, neighborhood integration.',
  life: 'Living in Wiesbaden: German rhythms, weekend travel, kids, pets, culture, day-to-day.',
  sponsors: 'How to be a good sponsor: what newcomers actually need from you.',
};

const phaseNum: Record<Phase, string> = {
  before: '01', arrive: '02', settle: '03', life: '04', sponsors: '05',
};

// Group entries by topic for visual segmentation
const byTopic = new Map<string, typeof sorted>();
for (const e of sorted) {
  const list = byTopic.get(e.data.topic) ?? [];
  list.push(e);
  byTopic.set(e.data.topic, list);
}
---
<BaseLayout title={`${PHASE_LABEL[phase]} — inpro`} description={phaseDescription[phase]}>
  <header class="phase-head">
    <p class="eyebrow">Phase {phaseNum[phase]}</p>
    <h1 class="display">{PHASE_LABEL[phase]}</h1>
    <p class="lead">{phaseDescription[phase]}</p>
  </header>

  {sorted.length === 0 ? (
    <p class="filter-empty">No entries yet for this phase. <a href={`${base}/`}>Return home</a>.</p>
  ) : (
    <div class="entry-stream">
      {Array.from(byTopic.entries()).map(([topic, entries]) => (
        <section class="topic-block">
          <h2 class="topic-marker">
            <span class="topic-name">{TOPIC_LABEL[topic as keyof typeof TOPIC_LABEL]}</span>
            <span class="topic-rule"></span>
            <span class="topic-count">{entries.length}</span>
          </h2>
          <ul class="entry-list">
            {entries.map((e: any) => (
              <li
                class="entry-row"
                data-profile={JSON.stringify(e.data.profile_tags ?? {})}
              >
                <a href={`${base}/entries/${e.slug}`} class="entry-link">
                  <h3>{e.data.title}</h3>
                  <p>{e.data.summary}</p>
                  <div class="entry-meta">
                    {e.data.poc_volatile && <span class="pill pill--terracotta">Verify first</span>}
                    {e.data.stub && <span class="pill pill--muted">Stub</span>}
                    <span class="verified">Verified {e.data.last_verified}</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}

  <style>
    .phase-head {
      margin: 0 0 4rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--rule-soft);
      max-width: 44rem;
    }
    .phase-head .eyebrow {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--terracotta);
      text-transform: none;
      letter-spacing: normal;
      font-weight: 400;
      font-variation-settings: "SOFT" 30, "WONK" 1, "opsz" 72;
    }
    .phase-head h1 { margin: 0.5rem 0 1.25rem; }
    .phase-head .lead {
      font-family: var(--font-sans);
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 42rem;
    }

    .entry-stream {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }
    .topic-block { padding-top: 1rem; }

    .topic-marker {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 0 0 1.25rem;
      font-size: 0.95rem;
      font-family: var(--font-sans);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--plum);
    }
    .topic-name { white-space: nowrap; }
    .topic-rule {
      flex: 1;
      height: 1px;
      background: var(--rule-soft);
    }
    .topic-count {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--terracotta);
      font-feature-settings: "tnum" 1;
      letter-spacing: -0.02em;
    }

    .entry-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .entry-row {
      border-top: 1px solid var(--rule-soft);
    }
    .entry-row:last-child {
      border-bottom: 1px solid var(--rule-soft);
    }
    .entry-link {
      display: block;
      padding: 1.5rem 0.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: background var(--transition), padding var(--transition);
    }
    .entry-link:hover {
      background: var(--paper-warm);
      padding-left: 1.25rem;
    }
    .entry-link h3 {
      margin: 0 0 0.5rem;
      font-size: 1.35rem;
      color: var(--ink);
      line-height: 1.25;
    }
    .entry-link:hover h3 { color: var(--plum); }
    .entry-link p {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--muted);
      margin: 0;
      max-width: 50rem;
    }

    .entry-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }
    .verified {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-feature-settings: "tnum" 1;
    }
  </style>
</BaseLayout>
