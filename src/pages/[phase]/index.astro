---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { PHASE_LABEL, TOPIC_LABEL, PHASES, type Phase } from '../../lib/tags';

export async function getStaticPaths() {
  return PHASES.map(phase => ({ params: { phase } }));
}

const { phase } = Astro.params as { phase: Phase };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('published', e => e.data.phase === phase);
const checklistCount = all.filter(e => e.data.checklist === true && !e.data.stub).length;
const sorted = all.sort((a, b) => {
  const ao = a.data.opinion ? 1 : 0;
  const bo = b.data.opinion ? 1 : 0;
  if (ao !== bo) return ao - bo;
  return (a.data.order - b.data.order) || a.data.title.localeCompare(b.data.title);
});

const phaseDescription: Record<Phase, string> = {
  before: 'Everything that has to happen before you leave CONUS — orders, EFMP, sponsor contact, passports, pets, POV prep.',
  arrive: 'Your first two weeks in Wiesbaden: lodging, ID enrollment, housing office, finance office, vehicle paperwork.',
  settle: '30 / 60 / 90-day tasks: Anmeldung, SOFA stamp, schools, healthcare enrollment, neighborhood integration.',
  life: 'Living in Wiesbaden: German rhythms, weekend travel, kids, pets, culture, day-to-day.',
  sponsors: 'How to be a good sponsor: what newcomers actually need from you.',
};

const phaseNum: Record<Phase, string> = {
  before: '01', arrive: '02', settle: '03', life: '04', sponsors: '05',
};

// Split opinion entries — they render in their own block at the bottom.
const factSorted = sorted.filter(e => !e.data.opinion);
const opinionSorted = sorted.filter(e => e.data.opinion);

// Group non-opinion entries by topic for visual segmentation
const byTopic = new Map<string, typeof factSorted>();
for (const e of factSorted) {
  const list = byTopic.get(e.data.topic) ?? [];
  list.push(e);
  byTopic.set(e.data.topic, list);
}
---
<BaseLayout title={`${PHASE_LABEL[phase]} — inpro`} description={phaseDescription[phase]}>
  <header class="phase-head">
    <p class="eyebrow">Phase {phaseNum[phase]}</p>
    <h1 class="display">{PHASE_LABEL[phase]}</h1>
    <p class="lead">{phaseDescription[phase]}</p>
    {checklistCount > 0 && (
      <p class="phase-cl-cta">
        <a href={`${base}/checklists/${phase}`}>
          <span class="phase-cl-label">Checklist</span>
          <span class="phase-cl-text">Track your progress through {checklistCount} key task{checklistCount === 1 ? '' : 's'}</span>
          <span class="phase-cl-arrow" aria-hidden="true">→</span>
        </a>
      </p>
    )}
  </header>

  {sorted.length === 0 ? (
    <p class="filter-empty">No entries yet for this phase. <a href={`${base}/`}>Return home</a>.</p>
  ) : (
    <div class="entry-stream">
      {Array.from(byTopic.entries()).map(([topic, entries]) => (
        <section class="topic-block">
          <h2 class="section-marker">
            <a href={`${base}/topics/${topic}`} class="section-name">{TOPIC_LABEL[topic as keyof typeof TOPIC_LABEL]}</a>
            <span class="section-rule"></span>
            <span class="section-count">{entries.length}</span>
          </h2>
          <ul class="entry-list">
            {entries.map((e: any) => (
              <li
                class="entry-row"
                data-profile={JSON.stringify(e.data.profile_tags ?? {})}
              >
                <a href={`${base}/entries/${e.slug}`} class="entry-link">
                  <h3>{e.data.title}</h3>
                  <p>{e.data.summary}</p>
                  <div class="entry-meta">
                    {e.data.poc_volatile && <span class="pill pill--terracotta">Verify first</span>}
                    {e.data.stub && <span class="pill pill--muted">Stub</span>}
                    <span class="verified">Verified {e.data.last_verified}</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}

      {opinionSorted.length > 0 && (
        <section class="topic-block opinion-block">
          <h2 class="section-marker">
            <span class="section-name">Opinion</span>
            <span class="section-rule"></span>
            <span class="section-count">{opinionSorted.length}</span>
          </h2>
          <p class="opinion-lead">Taste and judgement, not garrison policy.</p>
          <ul class="entry-list">
            {opinionSorted.map((e: any) => (
              <li
                class="entry-row"
                data-profile={JSON.stringify(e.data.profile_tags ?? {})}
              >
                <a href={`${base}/entries/${e.slug}`} class="entry-link">
                  <h3>{e.data.title}</h3>
                  <p>{e.data.summary}</p>
                  <div class="entry-meta">
                    <span class="pill pill--ochre">Opinion</span>
                    <span class="verified">Verified {e.data.last_verified}</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}

  <style>
    .phase-head {
      margin: 0 0 4rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--rule-soft);
      max-width: 44rem;
    }
    .phase-head .eyebrow {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--terracotta);
      text-transform: none;
      letter-spacing: normal;
      font-weight: 400;
      font-variation-settings: "SOFT" 30, "WONK" 1, "opsz" 72;
    }
    .phase-head h1 { margin: 0.5rem 0 1.25rem; }
    .phase-head .lead {
      font-family: var(--font-sans);
      font-size: 1.15rem;
      color: var(--muted-readable);
      max-width: 42rem;
    }
    .phase-cl-cta {
      margin: 1.5rem 0 0;
      max-width: 42rem;
    }
    .phase-cl-cta a {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.85rem 1rem;
      background: var(--paper-warm);
      border: 1px solid var(--rule-soft);
      border-radius: var(--radius);
      text-decoration: none;
      color: var(--ink);
      font-family: var(--font-sans);
      transition: all var(--transition);
    }
    .phase-cl-cta a:hover {
      border-color: var(--plum);
      background: var(--paper);
    }
    .phase-cl-label {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--plum);
      font-weight: 600;
    }
    .phase-cl-text {
      flex: 1;
      font-size: 0.95rem;
    }
    .phase-cl-arrow {
      color: var(--plum);
      font-size: 1.1rem;
    }

    .entry-stream {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }
    .topic-block { padding-top: 1rem; }
    .opinion-block .section-name { color: var(--ochre); }
    .opinion-lead {
      font-family: var(--font-sans);
      font-size: 0.88rem;
      color: var(--muted-readable);
      margin: 0 0 1rem;
      max-width: 44rem;
      font-style: italic;
    }

    .entry-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .entry-row {
      border-top: 1px solid var(--rule-soft);
    }
    .entry-row:last-child {
      border-bottom: 1px solid var(--rule-soft);
    }
    .entry-link {
      display: block;
      padding: 1.5rem 0.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: background var(--transition), padding var(--transition);
    }
    .entry-link:hover {
      background: var(--paper-warm);
      padding-left: 1.25rem;
    }
    .entry-link h3 {
      margin: 0 0 0.5rem;
      font-size: 1.35rem;
      color: var(--ink);
      line-height: 1.25;
    }
    .entry-link:hover h3 { color: var(--plum); }
    .entry-link p {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--muted-readable);
      margin: 0;
      max-width: 50rem;
    }

    .entry-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }
    .verified {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--muted-readable);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-feature-settings: "tnum" 1;
    }
  </style>
</BaseLayout>
