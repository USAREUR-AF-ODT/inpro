---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { TOPICS, TOPIC_LABEL, PHASE_LABEL, type Topic } from '../../lib/tags';

export async function getStaticPaths() {
  return TOPICS.map(topic => ({ params: { topic } }));
}

const { topic } = Astro.params as { topic: Topic };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('published', e => e.data.topic === topic);
const sorted = all.sort((a, b) => (a.data.order - b.data.order) || a.data.title.localeCompare(b.data.title));
---
<BaseLayout
  title={`${TOPIC_LABEL[topic]} — inpro`}
  description={`All ${TOPIC_LABEL[topic]} content for Wiesbaden PCS.`}
>
  <header class="topic-index-head">
    <p class="eyebrow">Topic</p>
    <h1 class="display">{TOPIC_LABEL[topic]}</h1>
    <p class="lead">{sorted.length} entries · tagged <code>{topic}</code></p>
  </header>

  {sorted.length === 0 ? (
    <p class="filter-empty">Nothing published under this topic yet. <a href={`${base}/`}>Return home</a>.</p>
  ) : (
    <ul class="entry-list">
      {sorted.map(e => (
        <li
          class="entry-row"
          data-profile={JSON.stringify(e.data.profile_tags ?? {})}
        >
          <a href={`${base}/entries/${e.slug}`} class="entry-link">
            <div class="entry-meta-top">
              <span class="pill pill--outline">{PHASE_LABEL[e.data.phase]}</span>
              {e.data.poc_volatile && <span class="pill pill--terracotta">Verify first</span>}
              {e.data.stub && <span class="pill pill--muted">Stub</span>}
            </div>
            <h3>{e.data.title}</h3>
            <p>{e.data.summary}</p>
            <p class="verified">Last verified {e.data.last_verified}</p>
          </a>
        </li>
      ))}
    </ul>
  )}

  <style>
    .topic-index-head {
      margin: 0 0 4rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--espresso-500);
    }
    .topic-index-head .eyebrow {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--terracotta);
      text-transform: none;
      letter-spacing: normal;
      font-weight: 400;
      font-variation-settings: "SOFT" 30, "WONK" 1, "opsz" 72;
    }
    .topic-index-head h1 { margin: 0.5rem 0 0.75rem; }
    .topic-index-head .lead {
      font-family: var(--font-sans);
      font-size: 1.05rem;
      color: var(--muted);
    }
    .topic-index-head code {
      background: var(--espresso-700);
      color: var(--ochre);
      padding: 0.1em 0.4em;
      border-radius: 2px;
      font-size: 0.9em;
    }

    .entry-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .entry-row {
      border-top: 1px solid var(--espresso-500);
    }
    .entry-row:last-child {
      border-bottom: 1px solid var(--espresso-500);
    }
    .entry-link {
      display: block;
      padding: 1.5rem 0.5rem;
      text-decoration: none;
      color: var(--paper);
      transition: background var(--transition), padding var(--transition);
    }
    .entry-link:hover {
      background: var(--espresso-700);
      padding-left: 1.25rem;
    }
    .entry-meta-top {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-bottom: 0.5rem;
    }
    .entry-link h3 {
      margin: 0 0 0.5rem;
      font-size: 1.35rem;
      color: var(--paper);
      line-height: 1.25;
    }
    .entry-link:hover h3 { color: var(--ochre); }
    .entry-link p {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--muted);
      margin: 0;
      max-width: 48rem;
    }
    .verified {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 0.5rem;
    }
  </style>
</BaseLayout>
