---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagPill from '../../components/TagPill.astro';
import { getCollection } from 'astro:content';
import { TOPICS, TOPIC_LABEL, PHASE_LABEL, type Topic } from '../../lib/tags';

export async function getStaticPaths() {
  return TOPICS.map(topic => ({ params: { topic } }));
}

const { topic } = Astro.params as { topic: Topic };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('published', e => e.data.topic === topic);
const sorted = all.sort((a, b) => (a.data.order - b.data.order) || a.data.title.localeCompare(b.data.title));
---
<BaseLayout
  title={`${TOPIC_LABEL[topic]} — inpro`}
  description={`All ${TOPIC_LABEL[topic]} content for Wiesbaden PCS.`}
>
  <header class="topic-index-head">
    <p class="eyebrow">Topic</p>
    <h1>{TOPIC_LABEL[topic]}</h1>
  </header>

  {sorted.length === 0 ? (
    <p class="filter-empty">Nothing published under this topic yet. <a href={`${base}/`}>Return home</a>.</p>
  ) : (
    <ul class="entry-list">
      {sorted.map(e => (
        <li
          class="entry-card"
          data-profile={JSON.stringify(e.data.profile_tags ?? {})}
        >
          <div class="ec-head">
            <TagPill variant="outline" label={PHASE_LABEL[e.data.phase]} />
            {e.data.stub && <TagPill variant="muted" label="Coming soon" />}
            {e.data.poc_volatile && <TagPill variant="terracotta" label="Verify before acting" />}
          </div>
          <h2><a href={`${base}/entries/${e.slug}`}>{e.data.title}</a></h2>
          <p>{e.data.summary}</p>
          <p class="meta">Last verified: {e.data.last_verified}</p>
        </li>
      ))}
    </ul>
  )}

  <style>
    .topic-index-head { margin-bottom: 2rem; }
    .eyebrow { font-family: var(--font-sans); font-size: .85rem; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin: 0; }
    .entry-list { list-style: none; padding: 0; display: grid; gap: 1rem; }
    .entry-card { padding: 1.25rem; background: var(--parchment); border: 1px solid var(--rule); border-radius: var(--radius); box-shadow: var(--shadow-card); }
    .ec-head { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: .5rem; }
    .entry-card h2 { margin: 0 0 .5rem; font-size: 1.15rem; }
    .entry-card h2 a { color: var(--ink); text-decoration: none; }
    .entry-card h2 a:hover { color: var(--burgundy); text-decoration: underline; }
    .entry-card p { margin: .25rem 0; font-family: var(--font-sans); }
    .meta { color: var(--muted); font-size: .85rem; }
  </style>
</BaseLayout>
