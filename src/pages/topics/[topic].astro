---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { TOPICS, TOPIC_LABEL, PHASES, PHASE_LABEL, type Topic, type Phase } from '../../lib/tags';

export async function getStaticPaths() {
  return TOPICS.map(topic => ({ params: { topic } }));
}

const { topic } = Astro.params as { topic: Topic };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('published', e => e.data.topic === topic);
const sorted = all.sort((a, b) => {
  const ao = a.data.opinion ? 1 : 0;
  const bo = b.data.opinion ? 1 : 0;
  if (ao !== bo) return ao - bo;
  return (a.data.order - b.data.order) || a.data.title.localeCompare(b.data.title);
});

// Split opinion entries out — they render in their own section at the bottom.
const factSorted = sorted.filter(e => !e.data.opinion);
const opinionSorted = sorted.filter(e => e.data.opinion);

// Group non-opinion entries by phase, in canonical phase order
const byPhase = new Map<Phase, typeof factSorted>();
for (const e of factSorted) {
  const phase = e.data.phase as Phase;
  const list = byPhase.get(phase) ?? [];
  list.push(e);
  byPhase.set(phase, list);
}
const orderedPhases = PHASES.filter(p => (byPhase.get(p)?.length ?? 0) > 0);

const topicIntro: Record<Topic, string> = {
  housing: 'On-post quarters or off-post lease, TLA math, HHG, and which neighborhoods reward which priorities. Start with the Housing Services Office.',
  finance: 'OHA, COLA, TLA, VAT forms, and reading your first German LES. Budget for the transition-month crunch; lean on Financial Readiness at ACS.',
  medical: 'Wiesbaden Army Health Clinic, TRICARE Overseas referrals through ATLAS, English-speaking specialists, emergency numbers. Dental is separate.',
  legal: 'Passports and SOFA stamp, Anmeldung for off-post residents, German bureaucracy. Wills and POAs through the on-post Legal Office.',
  vehicle: 'POV shipping, USAREUR registration, driver-license conversion, Autobahn rules, and the public transit that lets you live here without a car.',
  'id-cac': 'The administrative spine — CAC, DBIDS, DEERS, DSN codes, ID Card Center, APO mail, 110/220V electronics, and the essential pre- and post-arrival checklists.',
  family: 'ACS programs, CYS childcare and youth, spouse sponsorship, EFMP continuity, family advocacy, and spouse employment — the family-side support stack.',
  schools: 'DoDEA Wiesbaden schools, School Liaison Office, EFMP coordination, off-post German and international options.',
  pets: 'Bringing pets to Germany, the on-post VTF, German pet laws, and returning pets to the US at tour end.',
  religious: 'On-post chapel services through the Religious Support Office and off-post faith communities across traditions.',
  mwr: 'Commissary, PX, Shoppette, Wiesbaden Army Lodge, recreation, and the seasonal calendar of things actually worth doing.',
  unit: 'USAG Wiesbaden tenant units and what to expect your first week reporting for duty.',
};
---
<BaseLayout
  title={`${TOPIC_LABEL[topic]} — inpro`}
  description={`All ${TOPIC_LABEL[topic]} content for Wiesbaden PCS.`}
>
  <header class="topic-index-head">
    <p class="eyebrow">Topic</p>
    <h1 class="display">{TOPIC_LABEL[topic]}</h1>
    <p class="lead">{topicIntro[topic]}</p>
    <p class="topic-meta">{sorted.length} {sorted.length === 1 ? 'entry' : 'entries'} · across {orderedPhases.length} {orderedPhases.length === 1 ? 'phase' : 'phases'}</p>
  </header>

  {sorted.length === 0 ? (
    <p class="filter-empty">Nothing published under this topic yet. <a href={`${base}/`}>Return home</a>.</p>
  ) : (
    <div class="entry-stream">
      {orderedPhases.map(phase => {
        const entries = byPhase.get(phase) ?? [];
        return (
          <section class="phase-block">
            <h2 class="section-marker">
              <a href={`${base}/${phase}`} class="section-name">{PHASE_LABEL[phase]}</a>
              <span class="section-rule"></span>
              <span class="section-count">{entries.length}</span>
            </h2>
            <ul class="entry-list">
              {entries.map((e: any) => (
                <li
                  class="entry-row"
                  data-profile={JSON.stringify(e.data.profile_tags ?? {})}
                >
                  <a href={`${base}/entries/${e.slug}`} class="entry-link">
                    <h3>{e.data.title}</h3>
                    <p>{e.data.summary}</p>
                    <div class="entry-meta">
                      {e.data.poc_volatile && <span class="pill pill--terracotta">Verify first</span>}
                      {e.data.stub && <span class="pill pill--muted">Stub</span>}
                      <span class="verified">Verified {e.data.last_verified}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })}

      {opinionSorted.length > 0 && (
        <section class="phase-block opinion-block">
          <h2 class="section-marker">
            <span class="section-name">Opinion</span>
            <span class="section-rule"></span>
            <span class="section-count">{opinionSorted.length}</span>
          </h2>
          <p class="opinion-lead">Taste and judgement, not garrison policy. Useful after the facts land.</p>
          <ul class="entry-list">
            {opinionSorted.map((e: any) => (
              <li
                class="entry-row"
                data-profile={JSON.stringify(e.data.profile_tags ?? {})}
              >
                <a href={`${base}/entries/${e.slug}`} class="entry-link">
                  <h3>{e.data.title}</h3>
                  <p>{e.data.summary}</p>
                  <div class="entry-meta">
                    <span class="pill pill--ochre">Opinion</span>
                    <span class="verified">Verified {e.data.last_verified}</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}

  <style>
    .topic-index-head {
      margin: 0 0 4rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--rule-soft);
    }
    .topic-index-head .eyebrow {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--terracotta);
      text-transform: none;
      letter-spacing: normal;
      font-weight: 400;
      font-variation-settings: "SOFT" 30, "WONK" 1, "opsz" 72;
    }
    .topic-index-head h1 { margin: 0.5rem 0 1rem; }
    .topic-index-head .lead {
      font-family: var(--font-sans);
      font-size: 1.05rem;
      color: var(--ink);
      max-width: 44rem;
      line-height: 1.55;
      margin: 0 0 1rem;
    }
    .topic-meta {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin: 0;
    }

    .entry-stream {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }
    .phase-block { padding-top: 1rem; }
    .opinion-block .section-name { color: var(--ochre); }
    .opinion-lead {
      font-family: var(--font-sans);
      font-size: 0.88rem;
      color: var(--muted);
      margin: 0 0 1rem;
      max-width: 44rem;
      font-style: italic;
    }

    .entry-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .entry-row {
      border-top: 1px solid var(--rule-soft);
    }
    .entry-row:last-child {
      border-bottom: 1px solid var(--rule-soft);
    }
    .entry-link {
      display: block;
      padding: 1.5rem 0.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: background var(--transition), padding var(--transition);
    }
    .entry-link:hover {
      background: var(--paper-warm);
      padding-left: 1.25rem;
    }
    .entry-link h3 {
      margin: 0 0 0.5rem;
      font-size: 1.35rem;
      color: var(--ink);
      line-height: 1.25;
    }
    .entry-link:hover h3 { color: var(--plum); }
    .entry-link p {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--muted);
      margin: 0;
      max-width: 50rem;
    }

    .entry-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }
    .verified {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-feature-settings: "tnum" 1;
    }
  </style>
</BaseLayout>
