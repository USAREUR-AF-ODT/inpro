---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOPIC_LABEL, PHASE_LABEL, TOPICS, PHASES } from '../lib/tags';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('published');
const countByTopic = new Map(TOPICS.map(t => [t, 0]));
const countByPhase = new Map(PHASES.map(p => [p, 0]));
for (const e of all) {
  if (e.data.stub) continue;
  countByTopic.set(e.data.topic, (countByTopic.get(e.data.topic) ?? 0) + 1);
  countByPhase.set(e.data.phase, (countByPhase.get(e.data.phase) ?? 0) + 1);
}

const topicDescriptions: Record<typeof TOPICS[number], string> = {
  housing: 'On-post quarters, off-post leases, TLA, temporary lodging, neighborhood profiles.',
  finance: 'OHA, COLA, TLA, SOFA taxes, VAT forms, financial readiness.',
  medical: 'Wiesbaden Army Health Clinic, TRICARE Overseas enrollment, off-post hospitals, emergency numbers.',
  legal: 'Passports, SOFA cards, power of attorney, wills, lost-stolen checklists, German residency.',
  vehicle: 'POV shipment, USAREUR registration, driver license conversion, inspections, buses, taxis.',
  'id-cac': 'DBIDS, CAC replacement, SAAR, DSN dialing codes, ID cards for Family members.',
  family: 'ACS, CYS, spouse sponsorship, EFMP, lending closet, financial readiness, family advocacy.',
  schools: 'DoDEA Wiesbaden schools, School Liaison Office, registration, IEP transfer, off-post German schools.',
  pets: 'Pet import requirements, USDA health certificate, on-post VTF, German pet laws.',
  religious: 'Chapel services, Religious Support Office, worship schedule.',
  mwr: 'Family and MWR — libraries, fitness centers, Army Lodge, Outdoor Recreation, Amelia Earhart Playhouse.',
  unit: 'USAG Wiesbaden tenant units — V Corps, 2nd Theater Signal, 66th MI, 5th Signal, and more.',
};

const phaseDescriptions: Record<typeof PHASES[number], string> = {
  before: 'Orders, EFMP, sponsorship, passports, pet shots, POV prep.',
  arrive: 'Week one: HSO, finance, DES, ID enrollment, lodging.',
  settle: '30/60/90-day tasks: Anmeldung, SOFA stamp, schools, health enrollment.',
  life: 'Living here: German logistics, day trips, culture, day-to-day.',
  sponsors: 'How to be a good sponsor.',
};

const totalEntries = all.filter(e => !e.data.stub).length;
---
<BaseLayout title="inpro — Wiesbaden PCS guide" description="Unofficial, offline-capable information portal for anyone PCSing to Wiesbaden, Germany.">

  <!-- Minimal title header -->
  <header class="page-head">
    <h1 class="display">The unofficial <em>Wiesbaden</em> PCS guide.</h1>
    <p class="lead">{totalEntries} entries. No accounts, no tracking, works offline. Start where you are.</p>
  </header>

  <!-- Start here signpost -->
  <section class="signpost">
    <div class="signpost-row">
      <div class="signpost-text">
        <p class="eyebrow">Never PCSed overseas before?</p>
        <p class="signpost-lead">Start with <a href={`${base}/entries/housing/first-72-hours`}>The first 72 hours</a> — a run sheet for the three days after you land.</p>
      </div>
      <div class="signpost-text">
        <p class="eyebrow">Still in CONUS?</p>
        <p class="signpost-lead">Read <a href={`${base}/entries/vehicle/pov-shipping`}>POV shipping</a> and <a href={`${base}/entries/finance/cost-of-living`}>cost of living</a> before orders drop.</p>
      </div>
    </div>
  </section>

  <!-- Phase row (horizontal timeline) -->
  <section class="phase-row-wrap">
    <h2 class="section-label">By phase</h2>
    <ol class="phase-row">
      {PHASES.map((phase, i) => (
        <li>
          <a href={`${base}/${phase}`}>
            <span class="p-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="p-name">{PHASE_LABEL[phase]}</span>
            <span class="p-desc">{phaseDescriptions[phase]}</span>
            <span class="p-count">{countByPhase.get(phase) ?? 0}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <!-- Categorical topic index -->
  <section class="topic-index">
    <h2 class="section-label">By topic</h2>
    <ol class="topic-list">
      {TOPICS.map(topic => {
        const n = countByTopic.get(topic) ?? 0;
        return (
          <li>
            <a href={`${base}/topics/${topic}`} class="topic-row" data-empty={n === 0}>
              <span class="t-name">{TOPIC_LABEL[topic]}</span>
              <span class="t-desc">{topicDescriptions[topic]}</span>
              <span class="t-count">{n}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>

  <!-- Quick actions strip -->
  <section class="strip">
    <a class="strip-link" href={`${base}/search`}>
      <span class="strip-icon" aria-hidden="true">⌕</span>
      <span>Search all {totalEntries} entries</span>
      <span class="strip-arrow" aria-hidden="true">→</span>
    </a>
    <a class="strip-link" href={`${base}/about`}>
      <span class="strip-icon" aria-hidden="true">i</span>
      <span>About inpro (not affiliated with anyone)</span>
      <span class="strip-arrow" aria-hidden="true">→</span>
    </a>
  </section>

  <style>
    /* Notion/Linear style — dense, clean, functional */

    .page-head {
      margin: 0 0 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--rule-soft);
      max-width: 44rem;
    }
    .page-head h1 {
      margin: 0 0 0.5rem;
      font-size: clamp(1.85rem, 3.4vw, 2.6rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-variation-settings: "SOFT" 30, "WONK" 0, "opsz" 144;
    }
    .page-head h1 em {
      color: var(--terracotta);
      font-style: italic;
      font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
    }
    .page-head .lead {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--muted);
      margin: 0;
    }

    /* Signpost — start-here block */
    .signpost {
      margin-bottom: 2.5rem;
    }
    .signpost-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid var(--rule-soft);
    }
    .signpost-text {
      padding: 1.25rem 1.5rem;
      border-right: 1px solid var(--rule-soft);
    }
    .signpost-text:last-child { border-right: 0; }
    .signpost-lead {
      font-family: var(--font-display);
      font-size: 1.1rem;
      line-height: 1.35;
      margin: 0.35rem 0 0;
      color: var(--ink);
      font-variation-settings: "SOFT" 40, "WONK" 0, "opsz" 144;
    }
    .signpost-lead a {
      color: var(--plum);
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .signpost-lead a:hover {
      color: var(--terracotta);
    }
    @media (max-width: 700px) {
      .signpost-row { grid-template-columns: 1fr; }
      .signpost-text { border-right: 0; border-bottom: 1px solid var(--rule-soft); }
      .signpost-text:last-child { border-bottom: 0; }
    }

    .section-label {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
      margin: 0 0 0.75rem;
    }

    /* Phase row — compact horizontal list */
    .phase-row-wrap { margin-bottom: 2.5rem; }
    .phase-row {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      border: 1px solid var(--rule-soft);
    }
    .phase-row li { border-right: 1px solid var(--rule-soft); }
    .phase-row li:last-child { border-right: 0; }
    .phase-row a {
      display: grid;
      grid-template-rows: auto auto 1fr auto;
      gap: 0.2rem;
      padding: 0.75rem 0.85rem;
      text-decoration: none;
      color: var(--ink);
      height: 100%;
      transition: background var(--transition);
      min-height: 6rem;
      position: relative;
    }
    .phase-row a:hover { background: var(--paper-warm); color: var(--plum); }
    .p-num {
      font-family: var(--font-display);
      font-size: 0.9rem;
      color: var(--terracotta);
      font-feature-settings: "tnum" 1;
      letter-spacing: -0.02em;
      font-variation-settings: "SOFT" 50, "WONK" 1, "opsz" 72;
    }
    .p-name {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.01em;
      font-variation-settings: "SOFT" 30, "WONK" 0, "opsz" 144;
    }
    .p-desc {
      font-family: var(--font-sans);
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.35;
    }
    .p-count {
      position: absolute;
      top: 0.65rem;
      right: 0.8rem;
      font-family: var(--font-display);
      font-size: 0.8rem;
      color: var(--muted);
      font-feature-settings: "tnum" 1;
    }

    /* Topic list — Notion-style rows */
    .topic-index { margin-bottom: 2.5rem; }
    .topic-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .topic-list li { border-top: 1px solid var(--rule-soft); }
    .topic-list li:last-child { border-bottom: 1px solid var(--rule-soft); }
    .topic-row {
      display: grid;
      grid-template-columns: 11rem 1fr auto;
      gap: 1.5rem;
      align-items: baseline;
      padding: 0.75rem 0.25rem 0.75rem 0.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: background var(--transition), padding var(--transition);
    }
    .topic-row:hover {
      background: var(--paper-warm);
      padding-left: 1rem;
      color: var(--plum);
    }
    .topic-row[data-empty="true"] { color: var(--muted); }
    .t-name {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      font-variation-settings: "SOFT" 30, "WONK" 0, "opsz" 144;
    }
    .t-desc {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.45;
    }
    .t-count {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--muted);
      min-width: 2rem;
      text-align: right;
      font-feature-settings: "tnum" 1;
    }
    .topic-row[data-empty="true"] .t-count { opacity: 0.4; }

    /* Strip — secondary quick-action links */
    .strip {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-top: 1.5rem;
    }
    .strip-link {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0.75rem;
      align-items: center;
      padding: 0.9rem 1rem;
      border: 1px solid var(--rule-soft);
      text-decoration: none;
      color: var(--ink);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      transition: background var(--transition), border-color var(--transition);
    }
    .strip-link:hover {
      background: var(--paper-warm);
      border-color: var(--plum);
      color: var(--plum);
    }
    .strip-icon {
      font-family: var(--font-display);
      font-size: 1.3rem;
      color: var(--terracotta);
      font-style: italic;
      font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
      width: 1.4rem;
      text-align: center;
    }
    .strip-arrow { color: var(--muted); }

    @media (max-width: 800px) {
      .phase-row { grid-template-columns: 1fr 1fr; }
      .phase-row li { border-right: 1px solid var(--rule-soft); border-bottom: 1px solid var(--rule-soft); }
      .phase-row li:nth-child(2n) { border-right: 0; }
      .phase-row li:last-child { border-bottom: 0; }
      .topic-row { grid-template-columns: 1fr auto; }
      .t-desc { grid-column: 1 / -1; margin-top: 0.1rem; }
      .strip { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
