---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Offline — inpro">
  <section class="offline">
    <p class="eyebrow">Offline</p>
    <h1 class="display">You're <em>offline</em>.</h1>
    <p class="lead">The page you requested isn't cached yet. Pages you've already visited should still work.</p>

    <ul class="offline-list">
      <li><a href={`${base}/`}>Home</a> — category index</li>
      <li><a href={`${base}/arrive`}>When You Arrive</a></li>
      <li><a href={`${base}/entries/medical/emergency-numbers`}>Emergency numbers</a> (memorize these)</li>
      <li><a href={`${base}/search`}>Search</a></li>
    </ul>

    <p class="note">Service worker cache refreshes after each site update. Refresh while connected to Wi-Fi to get the latest.</p>
  </section>

  <style>
    .offline { max-width: 36rem; padding-top: 2rem; }
    .offline h1 {
      margin: 0.5rem 0 0.75rem;
    }
    .offline h1 em {
      color: var(--terracotta);
      font-style: italic;
      font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
    }
    .offline .lead {
      font-family: var(--font-sans);
      font-size: 1.1rem;
      color: var(--muted-readable);
    }
    .offline-list {
      list-style: none;
      padding: 0;
      margin: 2rem 0;
    }
    .offline-list li {
      padding: 0.75rem 0;
      border-top: 1px solid var(--rule-soft);
      font-family: var(--font-sans);
    }
    .offline-list li:last-child {
      border-bottom: 1px solid var(--rule-soft);
    }
    .note {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: var(--muted-readable);
      margin-top: 2rem;
    }
  </style>
</BaseLayout>
