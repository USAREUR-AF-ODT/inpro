---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import { getCollection } from 'astro:content';
const all = await getCollection('published');
const totalEntries = all.filter(e => !e.data.stub).length;

const exampleQueries = [
  'housing', 'OHA', 'DSN', 'Anmeldung', 'SOFA stamp', 'CYS',
  'HSO', 'TRICARE', 'EFMP', 'POV', 'VAT', 'driver license',
];
---
<BaseLayout title="Search — inpro" description="Search all inpro content for Wiesbaden PCS.">
  <header class="search-head">
    <p class="eyebrow">Search</p>
    <h1 class="display">Find <em>what you need</em>.</h1>
    <p class="lead">{totalEntries} entries searchable. Any POC's office, any acronym, any neighborhood.</p>
    <div class="example-chips" aria-label="Example searches">
      <span class="chips-label">Try:</span>
      {exampleQueries.map(q => (
        <button type="button" class="chip" data-query={q}>{q}</button>
      ))}
    </div>
  </header>
  <SearchBox />

  <script is:inline>
    document.querySelectorAll('.chip[data-query]').forEach(el => {
      el.addEventListener('click', () => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = el.dataset.query;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.focus();
        }
      });
    });

    // Honor the ?q=… SearchAction target declared in JSON-LD.
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');
    if (initialQuery) {
      const seed = () => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (!input) return false;
        input.value = initialQuery;
        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.focus();
        return true;
      };
      if (!seed()) {
        const obs = new MutationObserver(() => { if (seed()) obs.disconnect(); });
        obs.observe(document.body, { childList: true, subtree: true });
        setTimeout(() => obs.disconnect(), 5000);
      }
    }
  </script>

  <style>
    .search-head {
      margin-bottom: 2.5rem;
      max-width: 44rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--rule-soft);
    }
    .search-head h1 { margin: 0.5rem 0 0.75rem; }
    .search-head h1 em {
      color: var(--terracotta);
      font-style: italic;
      font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
    }
    .search-head .lead {
      font-family: var(--font-sans);
      color: var(--muted-readable);
      font-size: 1rem;
    }
    .example-chips {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.4rem;
    }
    .chips-label {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--muted-readable);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-right: 0.4rem;
    }
    .chip {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      padding: 0.25rem 0.65rem;
      background: transparent;
      color: var(--ink);
      border: 1px solid var(--rule-soft);
      border-radius: 999px;
      cursor: pointer;
      transition: all var(--transition);
    }
    .chip:hover {
      border-color: var(--plum);
      color: var(--plum);
      background: var(--paper-warm);
    }
  </style>
</BaseLayout>
