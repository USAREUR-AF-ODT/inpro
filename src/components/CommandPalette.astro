---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<div class="cmdk no-print" data-cmdk hidden role="dialog" aria-modal="true" aria-labelledby="cmdk-title">
  <div class="cmdk-backdrop" data-cmdk-close></div>
  <div class="cmdk-card" role="document">
    <div class="cmdk-input-row">
      <span class="cmdk-icon" aria-hidden="true">⌕</span>
      <input
        type="search"
        class="cmdk-input"
        data-cmdk-input
        placeholder="Search 62 entries…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search entries"
      />
      <kbd class="cmdk-esc">Esc</kbd>
    </div>
    <div class="cmdk-results" data-cmdk-results role="listbox" aria-label="Search results">
      <p class="cmdk-hint" data-cmdk-hint>
        Type to search. <kbd>↑</kbd><kbd>↓</kbd> to move, <kbd>Enter</kbd> to open.
      </p>
    </div>
    <div class="cmdk-foot">
      <span>Can't find it? <a href={`${base}/search`}>Open full search</a></span>
    </div>
  </div>
</div>

<style>
  .cmdk {
    position: fixed;
    inset: 0;
    z-index: 130;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 8vh 1rem 1rem;
  }
  .cmdk-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 22, 18, 0.55);
  }
  .cmdk-card {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lift);
    width: 100%;
    max-width: 40rem;
    font-family: var(--font-sans);
    display: flex;
    flex-direction: column;
    max-height: 80vh;
    overflow: hidden;
  }
  .cmdk-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.15rem;
    border-bottom: 1px solid var(--rule-soft);
  }
  .cmdk-icon {
    color: var(--plum);
    font-size: 1.1rem;
  }
  .cmdk-input {
    flex: 1;
    font: inherit;
    font-size: 1rem;
    background: transparent;
    border: 0;
    color: var(--ink);
    outline: none;
  }
  .cmdk-input::placeholder { color: var(--muted); }
  .cmdk-esc {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-bottom-width: 2px;
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
    color: var(--muted);
  }
  .cmdk-results {
    flex: 1;
    overflow-y: auto;
    padding: 0.4rem 0;
  }
  .cmdk-hint {
    padding: 0.9rem 1.15rem;
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .cmdk-hint kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-bottom-width: 2px;
    border-radius: 3px;
    padding: 0.05rem 0.35rem;
    color: var(--ink);
    margin: 0 0.15rem;
  }
  .cmdk-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.65rem 1.15rem;
    min-height: 44px;
    text-decoration: none;
    color: var(--ink);
    cursor: pointer;
    border-left: 2px solid transparent;
  }
  .cmdk-row:hover,
  .cmdk-row[data-active] {
    background: var(--paper-warm);
    border-left-color: var(--plum);
  }
  .cmdk-row-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink);
    font-variation-settings: "SOFT" 40, "WONK" 0, "opsz" 72;
  }
  .cmdk-row[data-active] .cmdk-row-title { color: var(--plum); }
  .cmdk-row-topic {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--plum);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--rule-soft);
    border-radius: 2px;
    white-space: nowrap;
  }
  .cmdk-row-excerpt {
    grid-column: 1 / -1;
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.4;
    margin: 0.15rem 0 0;
  }
  .cmdk-row-excerpt :global(mark) {
    background: transparent;
    color: var(--terracotta);
    font-weight: 600;
  }
  .cmdk-subrow {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.45rem 1.15rem 0.45rem 2.5rem;
    min-height: 34px;
    text-decoration: none;
    color: var(--ink);
    cursor: pointer;
    border-left: 2px solid transparent;
  }
  .cmdk-subrow:hover,
  .cmdk-subrow[data-active] {
    background: var(--paper-warm);
    border-left-color: var(--plum);
  }
  .cmdk-subrow-arrow {
    color: var(--muted);
    font-size: 0.85rem;
  }
  .cmdk-subrow[data-active] .cmdk-subrow-arrow { color: var(--plum); }
  .cmdk-subrow-title {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--ink);
    font-weight: 500;
  }
  .cmdk-subrow[data-active] .cmdk-subrow-title { color: var(--plum); }
  .cmdk-subrow-excerpt {
    grid-column: 2;
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.4;
    margin: 0.1rem 0 0;
  }
  .cmdk-subrow-excerpt :global(mark) {
    background: transparent;
    color: var(--terracotta);
    font-weight: 600;
  }

  .cmdk-empty {
    padding: 1.25rem 1.15rem;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .cmdk-foot {
    padding: 0.7rem 1.15rem;
    border-top: 1px solid var(--rule-soft);
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--paper-warm);
  }
  .cmdk-foot a { color: var(--plum); }

  @media (max-width: 600px) {
    .cmdk { padding-top: 2vh; }
  }
</style>
