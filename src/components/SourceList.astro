---
import TagPill from './TagPill.astro';
import { TIER_LABEL } from '../lib/tags';

export interface SourceScore {
  authority: number;
  currency: number;
  accuracy: number;
  purpose: number;
  license: number;
}
export interface Source {
  tier: 'T1' | 'T2' | 'T3' | 'T4';
  url: string;
  label: string;
  scraped?: string;
  score?: SourceScore;
}
export interface Props { sources: Source[]; lastVerified: string }

const { sources, lastVerified } = Astro.props;
---
<aside class="sources">
  <h2>Sources</h2>
  <p class="verified">Last verified: <time datetime={lastVerified}>{lastVerified}</time></p>
  {sources.length === 0 ? (
    <p class="empty">No external sources cited. Verify with the POC before acting on this.</p>
  ) : (
    <>
      <p class="tier-legend" aria-label="Source tier legend">
        <span><strong>T1</strong> {TIER_LABEL.T1}</span>
        <span class="tier-sep" aria-hidden="true">·</span>
        <span><strong>T2</strong> {TIER_LABEL.T2}</span>
        <span class="tier-sep" aria-hidden="true">·</span>
        <span><strong>T3</strong> {TIER_LABEL.T3}</span>
        <span class="tier-sep" aria-hidden="true">·</span>
        <span><strong>T4</strong> {TIER_LABEL.T4}</span>
      </p>
      <ul>
        {sources.map(s => (
          <li>
            <TagPill tier={s.tier} label={TIER_LABEL[s.tier]} />
            <a href={s.url} target="_blank" rel="noopener noreferrer">{s.label}</a>
            {s.scraped && <span class="scraped">· scraped {s.scraped}</span>}
            {s.score && (
              <span
                class="score-badge"
                title={`Authority ${s.score.authority}/5 · Currency ${s.score.currency}/5 · Accuracy ${s.score.accuracy}/5 · Purpose ${s.score.purpose}/5 · License ${s.score.license}/5`}
                aria-label={`Source score: authority ${s.score.authority} of 5, currency ${s.score.currency} of 5, accuracy ${s.score.accuracy} of 5`}
              >
                <span class="sb-dim">A{s.score.authority}</span>
                <span class="sb-dim">C{s.score.currency}</span>
                <span class="sb-dim">X{s.score.accuracy}</span>
              </span>
            )}
          </li>
        ))}
      </ul>
    </>
  )}
</aside>

<style>
  .sources {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    font-family: var(--font-sans);
  }
  .sources h2 { margin-top: 0; font-size: 1rem; }
  .verified { color: var(--muted-readable); font-size: .85rem; margin: .25rem 0 .75rem; }
  .tier-legend {
    display: flex;
    flex-wrap: wrap;
    gap: .35rem .5rem;
    align-items: center;
    margin: 0 0 1rem;
    padding: .5rem .7rem;
    background: var(--paper);
    border: 1px solid var(--rule-soft);
    border-radius: var(--radius-sm);
    font-size: .75rem;
    color: var(--muted-readable);
  }
  .tier-legend strong {
    font-family: var(--font-mono);
    font-size: .72rem;
    color: var(--plum);
    margin-right: .2rem;
  }
  .tier-sep { color: var(--rule); }
  .sources ul { list-style: none; padding: 0; margin: 0; display: grid; gap: .5rem; }
  .sources li { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; font-size: .92rem; }
  .scraped { color: var(--muted-readable); font-size: .8rem; }
  .empty { color: var(--muted-readable); font-size: .9rem; }
  .score-badge {
    display: inline-flex;
    gap: .25rem;
    padding: .1rem .4rem;
    background: var(--paper);
    border: 1px solid var(--rule-soft);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: .7rem;
    color: var(--muted-readable);
  }
  .sb-dim { letter-spacing: 0; }
</style>
