---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const h2s = headings.filter(h => h.depth === 2);
const show = h2s.length >= 3;
---
{show && (
  <aside class="entry-toc no-print" aria-labelledby="entry-toc-title">
    <details class="toc-details" open>
      <summary>
        <span id="entry-toc-title" class="toc-label">On this page</span>
        <span class="toc-chev" aria-hidden="true">▾</span>
      </summary>
      <nav>
        <ol>
          {h2s.map(h => (
            <li><a href={`#${h.slug}`} data-toc-link>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    </details>
  </aside>
)}

<style>
  .entry-toc {
    font-family: var(--font-sans);
    margin: 0 0 2rem;
  }
  .toc-details {
    border: 1px solid var(--rule-soft);
    border-radius: var(--radius-lg);
    background: var(--paper-warm);
    padding: 0.8rem 1rem;
  }
  .toc-details > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .toc-details > summary::-webkit-details-marker { display: none; }
  .toc-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
  }
  .toc-chev {
    color: var(--muted);
    transition: transform var(--transition);
  }
  .toc-details[open] .toc-chev { transform: rotate(180deg); }

  .entry-toc nav {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--rule-soft);
  }
  .entry-toc ol {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: toc;
    display: grid;
    gap: 0.15rem;
  }
  .entry-toc li {
    counter-increment: toc;
    padding: 0;
  }
  .entry-toc a {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    padding: 0.45rem 0.5rem;
    min-height: 32px;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.92rem;
    border-left: 2px solid transparent;
    border-radius: 2px;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }
  .entry-toc a::before {
    content: counter(toc, decimal-leading-zero);
    font-family: var(--font-display);
    font-feature-settings: "tnum" 1;
    color: var(--terracotta);
    font-size: 0.78rem;
    min-width: 1.6rem;
  }
  .entry-toc a:hover {
    color: var(--plum);
  }
  .entry-toc a[data-active] {
    color: var(--plum);
    border-left-color: var(--plum);
    background: var(--paper);
    font-weight: 600;
  }

  @media (min-width: 1100px) {
    .entry-toc {
      position: sticky;
      top: calc(var(--header-h, 6rem) + 3.5rem);
      margin: 0;
      max-height: calc(100vh - var(--header-h, 6rem) - 5rem);
      overflow-y: auto;
    }
    .toc-details {
      background: transparent;
      border: 0;
      padding: 0;
    }
    .toc-details > summary { cursor: default; }
    .toc-chev { display: none; }
    .entry-toc nav {
      border-top: none;
      margin-top: 0.5rem;
      padding-top: 0;
    }
  }
</style>
