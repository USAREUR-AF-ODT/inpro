---
---
<section class="recently-viewed no-print" data-recently-viewed aria-labelledby="recently-viewed-title">
  <div class="rv-head">
    <h2 class="section-label" id="recently-viewed-title" data-rv-title>Recently viewed</h2>
    <button type="button" class="rv-clear" data-rv-clear aria-label="Clear recent entries" hidden>Clear</button>
  </div>
  <ol class="rv-list" data-rv-list hidden></ol>
  <p class="rv-empty-hint" data-rv-empty-hint>
    Entries you open will appear here so you can resume where you left off.
    <button type="button" class="rv-dismiss" data-rv-dismiss aria-label="Dismiss hint">×</button>
  </p>
</section>

<style>
  .recently-viewed {
    margin-bottom: 2.5rem;
    padding: 1rem 1.25rem 1.1rem;
    border: 1px solid var(--rule-soft);
    background: var(--paper-warm);
    border-radius: var(--radius);
  }
  .rv-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .rv-head .section-label { margin: 0; }
  .rv-clear {
    background: none;
    border: none;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted-readable);
    cursor: pointer;
    padding: 0;
  }
  .rv-clear:hover { color: var(--plum); }

  .rv-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0;
  }
  .rv-list li {
    border-top: 1px solid var(--rule-soft);
  }
  .rv-list li:first-child,
  .rv-list li:nth-child(-n+1) { border-top: 0; }
  .rv-list a {
    display: grid;
    gap: 0.2rem;
    padding: 0.55rem 0.6rem;
    text-decoration: none;
    color: var(--ink);
    transition: background var(--transition);
  }
  .rv-list a:hover {
    background: var(--paper);
    color: var(--plum);
  }
  .rv-topic {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--plum);
  }
  .rv-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
  }
  .rv-list a:hover .rv-title { color: var(--plum); }

  @media (min-width: 700px) {
    .rv-list li:not(:first-child) { border-top: 0; border-left: 1px solid var(--rule-soft); }
    .rv-list li:first-child { border-left: 0; }
  }

  .rv-empty-hint {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--muted-readable);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .rv-dismiss {
    background: none;
    border: none;
    font-size: 1rem;
    line-height: 1;
    color: var(--muted-readable);
    cursor: pointer;
    padding: 0 0.25rem;
    margin-left: auto;
    min-width: 24px;
    min-height: 24px;
  }
  .rv-dismiss:hover { color: var(--plum); }
</style>
