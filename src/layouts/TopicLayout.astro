---
import BaseLayout from './BaseLayout.astro';
import SourceList from '../components/SourceList.astro';
import Card from '../components/Card.astro';
import FeedbackLink from '../components/FeedbackLink.astro';
import TagPill from '../components/TagPill.astro';
import { TOPIC_LABEL, PHASE_LABEL } from '../lib/tags';

export interface Props {
  frontmatter: any;
  slug: string;
  related?: any[];
}
const { frontmatter, slug, related = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const profileJson = JSON.stringify({
  status: frontmatter.profile_tags?.status,
  rank: frontmatter.profile_tags?.rank,
  accompanied: frontmatter.profile_tags?.accompanied,
  has_kids: frontmatter.profile_tags?.has_kids,
  has_pov: frontmatter.profile_tags?.has_pov,
  has_pets: frontmatter.profile_tags?.has_pets,
});
---
<BaseLayout title={`${frontmatter.title} — inpro`} description={frontmatter.summary}>
  <article
    class="topic"
    data-profile={profileJson}
    data-pagefind-body
    data-pagefind-filter={`topic:${frontmatter.topic}`}
  >
    <nav class="crumbs" aria-label="breadcrumb">
      <a href={`${base}/`}>Home</a>
      <span aria-hidden="true"> / </span>
      <a href={`${base}/${frontmatter.phase}`}>{PHASE_LABEL[frontmatter.phase as keyof typeof PHASE_LABEL]}</a>
      <span aria-hidden="true"> / </span>
      <a href={`${base}/topics/${frontmatter.topic}`}>{TOPIC_LABEL[frontmatter.topic as keyof typeof TOPIC_LABEL]}</a>
    </nav>

    <header class="topic-head">
      <div class="topic-pills">
        <span class="pill pill--outline">{TOPIC_LABEL[frontmatter.topic as keyof typeof TOPIC_LABEL]}</span>
        <span class="pill pill--outline">{PHASE_LABEL[frontmatter.phase as keyof typeof PHASE_LABEL]}</span>
        {frontmatter.poc_volatile && <span class="pill pill--terracotta">Verify before acting</span>}
      </div>
      <h1 class="display">{frontmatter.title}</h1>
      <p class="lead">{frontmatter.summary}</p>
      <p class="verified-stamp">
        <span>Last verified</span> <time datetime={frontmatter.last_verified}>{frontmatter.last_verified}</time>
      </p>
    </header>

    <div class="topic-body prose">
      <slot />
    </div>

    {frontmatter.poc?.length > 0 && (
      <section class="pocs">
        <h2>Points of contact</h2>
        <div class="poc-grid">
          {frontmatter.poc.map((p: any) => <Card poc={p} />)}
        </div>
      </section>
    )}

    <SourceList sources={frontmatter.sources ?? []} lastVerified={frontmatter.last_verified} />

    {related.length > 0 && (
      <section class="related">
        <h2 class="related-head">Read next</h2>
        <ul class="related-list">
          {related.map((r: any) => (
            <li>
              <a href={`${base}/entries/${r.slug}`}>
                <span class="r-topic">{r.data.topic}</span>
                <span class="r-title">{r.data.title}</span>
                <span class="r-summary">{r.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <FeedbackLink slug={slug} title={frontmatter.title} lastVerified={frontmatter.last_verified} />
  </article>

  <style>
    .topic {
      color: var(--ink);
    }

    .crumbs {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 2rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .crumbs a {
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 1px;
    }
    .crumbs a:hover {
      color: var(--plum);
      border-bottom-color: var(--plum);
    }

    .topic-head {
      margin: 0 0 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule-soft);
    }
    .topic-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 1rem;
    }
    .topic-head h1 {
      margin: 0 0 0.75rem;
      color: var(--ink);
      max-width: 40rem;
      font-variation-settings: "SOFT" 30, "WONK" 0, "opsz" 144;
    }
    .lead {
      font-family: var(--font-sans);
      font-size: 1.2rem;
      color: var(--ink-soft);
      max-width: 38rem;
      margin: 0;
      line-height: 1.5;
    }
    .verified-stamp {
      margin-top: 1.25rem;
      font-family: var(--font-sans);
      font-size: 0.78rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .verified-stamp span { color: var(--muted); }
    .verified-stamp time {
      color: var(--plum);
      font-weight: 600;
      font-feature-settings: "tnum" 1;
    }

    .topic-body {
      max-width: 44rem;
      font-size: 1.06rem;
      line-height: 1.65;
    }
    .topic-body :global(p:first-of-type) {
      font-size: 1.1rem;
    }
    .topic-body :global(h2) {
      margin-top: 3rem;
      padding-top: 1rem;
      font-size: 1.8rem;
      color: var(--plum);
      border-top: 1px solid var(--rule-soft);
    }
    .topic-body :global(h3) {
      margin-top: 2rem;
      font-size: 1.2rem;
      color: var(--ink);
    }
    .topic-body :global(ul), .topic-body :global(ol) { padding-left: 1.25rem; }
    .topic-body :global(li) { margin: 0.5rem 0; }
    .topic-body :global(strong) { color: var(--ink); font-weight: 700; }
    .topic-body :global(a) {
      color: var(--plum);
      text-decoration-color: rgba(122, 42, 62, 0.3);
    }
    .topic-body :global(a:hover) {
      color: var(--terracotta);
      text-decoration-color: var(--terracotta);
    }
    .topic-body :global(code) {
      background: var(--paper-warm);
      color: var(--plum);
      padding: 0.1em 0.35em;
      border-radius: 2px;
      font-size: 0.9em;
    }
    .topic-body :global(blockquote) {
      margin: 2rem 0;
      padding: 1rem 1.5rem;
      border-left: 3px solid var(--terracotta);
      background: var(--paper-warm);
      font-style: italic;
    }
    .topic-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .topic-body :global(th), .topic-body :global(td) {
      padding: 0.6rem 0.8rem;
      border: 1px solid var(--rule-soft);
      text-align: left;
    }
    .topic-body :global(th) {
      background: var(--paper-warm);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.8rem;
    }

    .pocs {
      margin-top: 3.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule-soft);
    }
    .pocs h2 {
      color: var(--plum);
      font-size: 1.6rem;
    }
    .poc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .related {
      margin-top: 3.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule-soft);
    }
    .related-head {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
      margin: 0 0 1rem;
    }
    .related-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: 0;
    }
    .related-list li {
      border-top: 1px solid var(--rule-soft);
    }
    .related-list li:last-child {
      border-bottom: 1px solid var(--rule-soft);
    }
    .related-list a {
      display: grid;
      grid-template-rows: auto auto auto;
      gap: 0.25rem;
      padding: 0.9rem 0.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: background var(--transition), padding var(--transition);
    }
    .related-list a:hover {
      background: var(--paper-warm);
      padding-left: 1rem;
      color: var(--plum);
    }
    .r-topic {
      font-family: var(--font-sans);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--plum);
    }
    .r-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 500;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .related-list a:hover .r-title { color: var(--plum); }
    .r-summary {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: var(--muted);
    }

    @media (min-width: 700px) {
      .related-list { grid-template-columns: 1fr 1fr; }
      .related-list li { border-right: 1px solid var(--rule-soft); }
      .related-list li:nth-child(2n) { border-right: 0; }
    }
  </style>
</BaseLayout>
