---
import BaseLayout from './BaseLayout.astro';
import SourceList from '../components/SourceList.astro';
import Card from '../components/Card.astro';
import FeedbackLink from '../components/FeedbackLink.astro';
import EntryTOC from '../components/EntryTOC.astro';
import PrevNext from '../components/PrevNext.astro';
import TopicSwitcher from '../components/TopicSwitcher.astro';
import { TOPIC_LABEL, PHASE_LABEL, type Topic } from '../lib/tags';

export interface Props {
  frontmatter: any;
  slug: string;
  related?: any[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  prev?: { slug: string; title: string; topic: Topic } | null;
  next?: { slug: string; title: string; topic: Topic } | null;
  readMinutes?: number;
}
const { frontmatter, slug, related = [], headings = [], prev = null, next = null, readMinutes } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const profileJson = JSON.stringify({
  status: frontmatter.profile_tags?.status,
  rank: frontmatter.profile_tags?.rank,
  accompanied: frontmatter.profile_tags?.accompanied,
  has_kids: frontmatter.profile_tags?.has_kids,
  has_pov: frontmatter.profile_tags?.has_pov,
  has_pets: frontmatter.profile_tags?.has_pets,
});
const topicLabel = TOPIC_LABEL[frontmatter.topic as Topic];
---
<BaseLayout title={`${frontmatter.title} — inpro`} description={frontmatter.summary} activePhase={frontmatter.phase} entryMeta={{ slug, title: frontmatter.title, topic: frontmatter.topic }}>
  <article
    class="topic"
    data-profile={profileJson}
    data-pagefind-body
    data-pagefind-filter={`topic:${frontmatter.topic}`}
  >
    <span data-pagefind-filter={`phase:${frontmatter.phase}`} hidden></span>
    <div class="crumbs-strip">
      <nav class="crumbs" aria-label="breadcrumb">
        <a href={`${base}/`}>Home</a>
        <span class="crumb-sep" aria-hidden="true">/</span>
        <a href={`${base}/${frontmatter.phase}`}>{PHASE_LABEL[frontmatter.phase as keyof typeof PHASE_LABEL]}</a>
        <span class="crumb-sep" aria-hidden="true">/</span>
        <TopicSwitcher current={frontmatter.topic as Topic} />
        <span class="crumb-sep" aria-hidden="true">/</span>
        <span class="crumb-current" aria-current="page">{frontmatter.title}</span>
      </nav>
    </div>

    <header class="topic-head">
      <div class="topic-pills">
        <span class="pill pill--outline">{topicLabel}</span>
        <span class="pill pill--outline">{PHASE_LABEL[frontmatter.phase as keyof typeof PHASE_LABEL]}</span>
        {frontmatter.opinion && <span class="pill pill--ochre">Opinion</span>}
        {frontmatter.poc_volatile && <span class="pill pill--terracotta">Verify before acting</span>}
      </div>
      {frontmatter.checklist && <p class="briefing-eyebrow">Briefing</p>}
      <h1 class="display">{frontmatter.title}</h1>
      <p class="lead">{frontmatter.summary}</p>
      <p class="entry-meta-strip">
        <span class="verified-stamp">
          <span>Last verified</span> <time datetime={frontmatter.last_verified}>{frontmatter.last_verified}</time>
        </span>
        {readMinutes && <span class="read-time">{readMinutes} min read</span>}
      </p>
    </header>

    <div class="topic-grid">
      <EntryTOC headings={headings} />
      <div class="topic-body prose">
        <slot />
      </div>
    </div>

    {frontmatter.poc?.length > 0 && (
      <section class="pocs">
        <h2>Points of contact</h2>
        <div class="poc-grid">
          {frontmatter.poc.map((p: any) => <Card poc={p} />)}
        </div>
      </section>
    )}

    <SourceList sources={frontmatter.sources ?? []} lastVerified={frontmatter.last_verified} />

    <PrevNext prev={prev} next={next} topicLabel={topicLabel} />

    {related.length > 0 && (
      <section class="related">
        <h2 class="related-head">Read next</h2>
        <ul class="related-list">
          {related.map((r: any) => (
            <li>
              <a href={`${base}/entries/${r.slug}`}>
                <span class="r-topic">{TOPIC_LABEL[r.data.topic as Topic]}</span>
                <span class="r-title">{r.data.title}</span>
                <span class="r-summary">{r.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <FeedbackLink slug={slug} title={frontmatter.title} lastVerified={frontmatter.last_verified} />
  </article>

  <style>
    .topic {
      color: var(--ink);
    }

    .crumbs-strip {
      position: sticky;
      top: var(--header-h, 0px);
      z-index: 30;
      background: color-mix(in srgb, var(--paper) 94%, transparent);
      backdrop-filter: saturate(120%) blur(10px);
      margin: -2.5rem -1.5rem 2rem;
      padding: 0.55rem 1.5rem;
      border-bottom: 1px solid var(--rule-soft);
    }
    .crumbs {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      color: var(--muted-readable);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      flex-wrap: wrap;
      max-width: 76rem;
      margin: 0 auto;
    }
    .crumbs > a {
      color: var(--muted-readable);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 1px;
    }
    .crumbs > a:hover {
      color: var(--plum);
      border-bottom-color: var(--plum);
    }
    .crumb-sep { color: var(--rule); }
    .crumb-current {
      color: var(--plum);
      font-weight: 600;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 22rem;
    }
    @media (max-width: 720px) {
      .crumb-current { max-width: 12rem; }
    }

    .topic-head {
      margin: 0 0 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule-soft);
    }
    .topic-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 1rem;
    }
    .topic-head h1 {
      margin: 0 0 0.75rem;
      color: var(--ink);
      max-width: 40rem;
      font-variation-settings: "SOFT" 30, "WONK" 0, "opsz" 144;
    }
    .lead {
      font-family: var(--font-sans);
      font-size: 1.2rem;
      color: var(--ink-soft);
      max-width: 38rem;
      margin: 0;
      line-height: 1.5;
    }
    .briefing-eyebrow {
      font-family: var(--font-sans);
      font-size: 0.68rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--ochre);
      margin: 0 0 0.3rem;
    }
    .entry-meta-strip {
      margin-top: 1.5rem;
      display: inline-flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.6rem;
    }
    .verified-stamp {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--muted-readable);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      padding: 0.4rem 0.8rem;
      border: 1px solid var(--rule-soft);
      border-radius: 2px;
      background: var(--paper-warm);
    }
    .read-time {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--muted-readable);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      padding: 0.4rem 0.8rem;
      border: 1px dashed var(--rule-soft);
      border-radius: 2px;
    }
    .verified-stamp::before {
      content: "";
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--forest);
    }
    .verified-stamp span { color: var(--muted-readable); }
    .verified-stamp time {
      color: var(--plum);
      font-weight: 600;
      font-feature-settings: "tnum" 1;
    }

    .topic-grid {
      display: block;
    }
    .topic-body {
      max-width: 44rem;
      font-size: 1.06rem;
      line-height: 1.65;
    }
    @media (min-width: 1100px) {
      .topic-grid {
        display: grid;
        grid-template-columns: minmax(0, 44rem) 16rem;
        grid-template-areas: "body toc";
        gap: 3rem;
        align-items: start;
      }
      .topic-body { max-width: none; grid-area: body; }
      .topic-grid > :global(aside.entry-toc) { grid-area: toc; }
    }
    .topic-body :global(p:first-of-type) {
      font-size: 1.1rem;
    }
    .topic-body :global(h2) {
      margin-top: 3rem;
      padding-top: 1rem;
      font-size: 1.8rem;
      color: var(--plum);
      border-top: 1px solid var(--rule-soft);
    }
    .topic-body :global(h3) {
      margin-top: 2rem;
      font-size: 1.2rem;
      color: var(--ink);
    }
    .topic-body :global(ul), .topic-body :global(ol) { padding-left: 1.25rem; }
    .topic-body :global(li) { margin: 0.5rem 0; }
    .topic-body :global(strong) { color: var(--ink); font-weight: 700; }
    .topic-body :global(a) {
      color: var(--plum);
      text-decoration-color: rgba(122, 42, 62, 0.3);
    }
    .topic-body :global(a:hover) {
      color: var(--terracotta);
      text-decoration-color: var(--terracotta);
    }
    .topic-body :global(code) {
      background: var(--paper-warm);
      color: var(--plum);
      padding: 0.1em 0.35em;
      border-radius: 2px;
      font-size: 0.9em;
    }
    .topic-body :global(blockquote) {
      margin: 2rem 0;
      padding: 1rem 1.5rem;
      border-left: 3px solid var(--terracotta);
      background: var(--paper-warm);
      font-style: italic;
    }
    .topic-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .topic-body :global(th), .topic-body :global(td) {
      padding: 0.6rem 0.8rem;
      border: 1px solid var(--rule-soft);
      text-align: left;
    }
    .topic-body :global(th) {
      background: var(--paper-warm);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.8rem;
    }

    .pocs {
      margin-top: 3.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule-soft);
    }
    .pocs h2 {
      color: var(--plum);
      font-size: 1.6rem;
    }
    .poc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .related {
      margin-top: 3.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule-soft);
    }
    .related-head {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted-readable);
      margin: 0 0 1rem;
    }
    .related-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: 0;
    }
    .related-list li {
      border-top: 1px solid var(--rule-soft);
    }
    .related-list li:last-child {
      border-bottom: 1px solid var(--rule-soft);
    }
    .related-list a {
      display: grid;
      grid-template-rows: auto auto auto;
      gap: 0.25rem;
      padding: 0.9rem 0.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: background var(--transition), padding var(--transition);
    }
    .related-list a:hover {
      background: var(--paper-warm);
      padding-left: 1rem;
      color: var(--plum);
    }
    .r-topic {
      font-family: var(--font-sans);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--plum);
    }
    .r-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 500;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .related-list a:hover .r-title { color: var(--plum); }
    .r-summary {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: var(--muted-readable);
    }

    @media (min-width: 700px) {
      .related-list { grid-template-columns: 1fr 1fr; }
      .related-list li { border-right: 1px solid var(--rule-soft); }
      .related-list li:nth-child(2n) { border-right: 0; }
    }
  </style>
</BaseLayout>
