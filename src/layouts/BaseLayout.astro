---
import '../styles/global.css';
import MobileNav from '../components/MobileNav.astro';
import BackToTop from '../components/BackToTop.astro';
import ShortcutsOverlay from '../components/ShortcutsOverlay.astro';
import ProfileFilterStatus from '../components/ProfileFilterStatus.astro';
import CommandPalette from '../components/CommandPalette.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  activePhase?: string;
  entryMeta?: { slug: string; title: string; topic: string };
}
const { title, description = 'Unofficial PCS guide for Wiesbaden, Germany.', ogImage, activePhase, entryMeta } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321').toString();
const ogImg = ogImage ?? `${base}/og-default.png`;
// M-ip-04 fix (2026-04-26): Cloudflare Insights beacon removed to honor the
// "No tracking" claim in the footer. The PUBLIC_CF_ANALYTICS_TOKEN env var is
// no longer read; if a future change wants analytics, also update the footer.
const siteOrigin = (Astro.site ?? new URL('http://localhost:4321')).origin;
const siteHome = new URL(`${base}/`, siteOrigin).toString();
const ogImgAbs = new URL(ogImg, siteOrigin).toString();
const isHome = Astro.url.pathname.replace(/\/$/, '') === base.replace(/\/$/, '');
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'inpro',
    alternateName: 'Wiesbaden PCS guide',
    description: 'Unofficial, offline-capable PCS information portal for Wiesbaden, Germany.',
    url: siteHome,
    inLanguage: 'en',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${siteHome}search?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'inpro contributors',
    description: 'Community-maintained, unofficial PCS information portal for USAG Wiesbaden personnel and families. Not affiliated with the US Army, DoD, or USAG Wiesbaden.',
    url: siteHome,
    logo: ogImgAbs,
  },
];
const path = Astro.url.pathname.replace(/\/$/, '');
const basePath = base.replace(/\/$/, '');
function isPhaseActive(phase: string): boolean {
  if (activePhase && activePhase === phase) return true;
  const p = `${basePath}/${phase}`;
  return path === p || path.startsWith(`${p}/`);
}
const phases: Array<[string, string, string]> = [
  ['before', '01', 'Before'],
  ['arrive', '02', 'Arrive'],
  ['settle', '03', 'Settle'],
  ['life', '04', 'Life'],
  ['sponsors', '05', 'Sponsors'],
];
const searchActive = path === `${basePath}/search`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#F6EFE1" />
    <meta name="inpro-base" content={base} />
    {entryMeta && (
      <meta
        name="inpro-entry"
        data-slug={entryMeta.slug}
        data-title={entryMeta.title}
        data-topic={entryMeta.topic}
      />
    )}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="alternate" type="application/rss+xml" title="inpro updates" href={`${base}/feed.xml`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    {isHome && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="masthead">
        <a href={`${base}/`} class="brand">
          <span class="brand-mark">in<i>/</i>pro</span>
          <span class="brand-sub">The unofficial Wiesbaden PCS guide</span>
        </a>
        <span data-pp-badge class="no-print badge-slot"></span>
        <MobileNav />
      </div>

      <nav class="primary-nav" aria-label="Primary">
        <div class="nav-inner">
          {phases.map(([slug, num, label]) => (
            <a
              href={`${base}/${slug}`}
              aria-current={isPhaseActive(slug) ? 'page' : undefined}
              class:list={[{ active: isPhaseActive(slug) }]}
            >
              <span class="num">{num}</span> {label}
            </a>
          ))}
          <a
            href={`${base}/search`}
            class:list={['search-link', { active: searchActive }]}
            aria-current={searchActive ? 'page' : undefined}
            aria-label="Search"
          >⌕ Search</a>
        </div>
      </nav>
    </header>

    <div data-pp-banner class="banner-wrap no-print">
      <div class="pp-banner">
        <p><strong>New here?</strong> Set your view so we can highlight what's relevant to your situation. No signup, stays on your device.</p>
        <div class="pp-actions">
          <button type="button" class="btn" data-pp-open>Set my view</button>
          <button type="button" class="btn btn--ghost" data-pp-skip>Skip — show everything</button>
        </div>
      </div>
    </div>
    <ProfileFilterStatus />

    <main id="main">
      <slot />
    </main>

    <BackToTop />
    <ShortcutsOverlay />
    <CommandPalette />

    <footer class="site-footer no-print">
      <div class="ft-inner">
        <div class="ft-col">
          <p class="ft-brand">in<i>/</i>pro</p>
          <p class="ft-tagline">Unofficial PCS guide for Wiesbaden. No tracking. No affiliation. No promises beyond "last verified."</p>
        </div>
        <div class="ft-col">
          <p class="eyebrow">Not affiliated</p>
          <p>inpro is not affiliated with the US Army, the Department of War, DoD, or USAG Wiesbaden. All content is unclass and community-verified.</p>
          <p class="ft-disclaimer">Information only — not legal, medical, or financial advice. Verify with a qualified professional, your sponsor, or an official source before acting on anything you read here.</p>
        </div>
        <div class="ft-col">
          <p class="eyebrow">Links</p>
          <a href={`${base}/about`}>About</a>
          <a href={`${base}/search`}>Search</a>
          <a href={`${base}/feed.xml`}>RSS feed</a>
          <a href={`${base}/about`}>Report outdated info</a>
        </div>
      </div>
      <div class="ft-rule"></div>
      <p class="ft-copy">© inpro contributors. Code MIT · Content CC-BY-SA 4.0.</p>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--paper) 94%, transparent);
        backdrop-filter: saturate(120%) blur(12px);
        border-bottom: 1px solid var(--rule-soft);
      }
      .masthead {
        max-width: 76rem;
        margin: 0 auto;
        padding: 1.25rem 1.5rem 0.5rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }
      .brand {
        display: inline-flex;
        flex-direction: column;
        text-decoration: none;
        color: var(--ink);
      }
      .brand:hover { color: var(--plum); }
      .brand-mark {
        font-family: var(--font-display);
        font-size: 2.2rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: -0.04em;
        font-variation-settings: "SOFT" 20, "WONK" 1, "opsz" 144;
      }
      .brand-mark i {
        color: var(--terracotta);
        font-style: italic;
        font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
      }
      .brand-sub {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--muted-readable);
        margin-top: 0.3rem;
      }
      .badge-slot { margin-left: auto; align-self: center; }

      .primary-nav {
        border-top: 1px solid var(--rule-soft);
        margin-top: 0.75rem;
      }
      .nav-inner {
        max-width: 76rem;
        margin: 0 auto;
        padding: 0.6rem 1.5rem;
        display: flex;
        gap: 2rem;
        font-family: var(--font-sans);
        overflow-x: auto;
        scrollbar-width: none;
      }
      .nav-inner::-webkit-scrollbar { display: none; }
      .nav-inner a {
        color: var(--ink);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        white-space: nowrap;
        padding: 0.2rem 0;
        border-bottom: 2px solid transparent;
        transition: border-color var(--transition), color var(--transition);
      }
      .nav-inner a:hover {
        border-bottom-color: var(--plum);
        color: var(--plum);
      }
      .nav-inner a.active,
      .nav-inner a[aria-current="page"] {
        border-bottom-color: var(--plum);
        color: var(--plum);
        font-weight: 600;
      }
      .nav-inner .num {
        font-family: var(--font-display);
        color: var(--terracotta-600);
        font-size: 0.75rem;
        margin-right: 0.35rem;
        font-feature-settings: "tnum" 1;
        font-variation-settings: "SOFT" 50, "WONK" 1, "opsz" 72;
      }
      .nav-inner .search-link { margin-left: auto; color: var(--plum); }

      .banner-wrap {
        max-width: 76rem;
        margin: 1.5rem auto 0;
        padding: 0 1.5rem;
      }
      /* SSR copy of .pp-banner styles from profilePicker.client.ts.
         Inlined so first paint matches the hydrated layout and CLS stays at 0. */
      .pp-banner {
        background: var(--paper-warm);
        border: 1px solid var(--rule);
        border-radius: var(--radius);
        padding: 0.9rem 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-sans);
        font-size: 0.95rem;
      }
      .pp-banner p { margin: 0; flex: 1 1 20rem; }
      .pp-banner .pp-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }
      .pp-banner .btn {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        padding: 0.4rem 0.85rem;
        border-radius: var(--radius);
        border: 1px solid var(--rule);
        background: var(--ink);
        color: var(--paper);
        cursor: pointer;
      }
      .pp-banner .btn--ghost {
        background: transparent;
        color: var(--ink);
      }

      main {
        max-width: 76rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 5rem;
      }

      .site-footer {
        border-top: 1px solid var(--rule-soft);
        background: var(--paper-warm);
        font-family: var(--font-sans);
        color: var(--ink);
        margin-top: 4rem;
      }
      .ft-inner {
        max-width: 76rem;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
      }
      .ft-col { display: flex; flex-direction: column; gap: 0.4rem; }
      .ft-col a { color: var(--plum); }
      .ft-brand {
        font-family: var(--font-display);
        font-size: 1.6rem;
        letter-spacing: -0.03em;
        margin: 0;
        font-variation-settings: "SOFT" 20, "WONK" 1, "opsz" 144;
        color: var(--ink);
      }
      .ft-brand i { color: var(--terracotta); font-style: italic; }
      .ft-tagline { font-size: 0.9rem; color: var(--muted-readable); margin: 0; }
      .ft-col p { margin: 0; font-size: 0.9rem; line-height: 1.5; color: var(--ink); }
      .ft-col .eyebrow { color: var(--plum); margin-bottom: 0.4rem; }
      .ft-disclaimer { font-size: 0.82rem !important; color: var(--muted-readable) !important; margin-top: 0.6rem !important; }
      .ft-rule {
        max-width: 76rem;
        margin: 0 auto;
        border-top: 1px solid var(--rule-soft);
      }
      .ft-copy {
        max-width: 76rem;
        margin: 0 auto;
        padding: 1rem 1.5rem 2rem;
        font-size: 0.78rem;
        color: var(--muted-readable);
      }

      @media (max-width: 720px) {
        .ft-inner { grid-template-columns: 1fr; gap: 2rem; }
        .nav-inner { gap: 1rem; font-size: 0.85rem; }
        .brand-sub { font-size: 0.65rem; }
        .badge-slot { display: none; }
        .primary-nav { display: none; }
      }
    </style>

    <script>
      import '../islands/profilePicker.client.ts';
      import '../islands/profileFilter.client.ts';
      import '../islands/mobileNav.client.ts';
      import '../islands/backToTop.client.ts';
      import '../islands/shortcuts.client.ts';
      import '../islands/tocActive.client.ts';
      import '../islands/commandPalette.client.ts';
      import '../islands/headerHeight.client.ts';
      import '../islands/recentTracker.client.ts';
      import '../islands/recentlyViewed.client.ts';
    </script>
  </body>
</html>
