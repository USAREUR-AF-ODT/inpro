---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  paper?: boolean;
}
const { title, description = 'Unofficial PCS guide for Wiesbaden, Germany.', ogImage, paper = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321').toString();
const ogImg = ogImage ?? `${base}/og-default.png`;
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#1A1612" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    {cfToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfToken}"}`}
      />
    )}
  </head>
  <body class={paper ? 'paper' : ''}>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="masthead">
        <a href={`${base}/`} class="brand" aria-label="inpro — home">
          <span class="brand-mark">in<i>/</i>pro</span>
          <span class="brand-sub">The unofficial Wiesbaden PCS guide</span>
        </a>
        <span data-pp-badge class="no-print badge-slot"></span>
      </div>

      <nav class="primary-nav" aria-label="Primary">
        <div class="nav-inner">
          <a href={`${base}/before`}><span class="num">01</span> Before</a>
          <a href={`${base}/arrive`}><span class="num">02</span> Arrive</a>
          <a href={`${base}/settle`}><span class="num">03</span> Settle</a>
          <a href={`${base}/life`}><span class="num">04</span> Life</a>
          <a href={`${base}/sponsors`}><span class="num">05</span> Sponsors</a>
          <a href={`${base}/search`} class="search-link" aria-label="Search">⌕ Search</a>
        </div>
      </nav>
    </header>

    <div data-pp-banner class="banner-wrap no-print"></div>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer no-print">
      <div class="ft-inner">
        <div class="ft-col">
          <p class="ft-brand">in<i>/</i>pro</p>
          <p class="ft-tagline">Unofficial PCS guide for Wiesbaden. No tracking. No affiliation. No promises beyond "last verified."</p>
        </div>
        <div class="ft-col">
          <p class="eyebrow">Not affiliated</p>
          <p>inpro is not affiliated with the US Army, the Department of War, DoD, or USAG Wiesbaden. All content is unclass and community-verified.</p>
        </div>
        <div class="ft-col">
          <p class="eyebrow">Links</p>
          <a href={`${base}/about`}>About</a>
          <a href="https://github.com/" target="_blank" rel="noopener">Contribute on GitHub</a>
          <a href={`${base}/search`}>Search</a>
        </div>
      </div>
      <div class="ft-rule"></div>
      <p class="ft-copy">© inpro contributors. Code MIT · Content CC-BY-SA 4.0.</p>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--espresso) 95%, transparent);
        backdrop-filter: saturate(120%) blur(12px);
        border-bottom: 1px solid var(--espresso-500);
      }
      .paper .site-header {
        background: color-mix(in srgb, var(--paper) 94%, transparent);
        border-bottom: 1px solid var(--rule-soft);
      }
      .masthead {
        max-width: 76rem;
        margin: 0 auto;
        padding: 1.25rem 1.5rem 0.5rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }
      .brand {
        display: inline-flex;
        flex-direction: column;
        text-decoration: none;
        color: var(--paper);
      }
      .paper .brand { color: var(--ink); }
      .brand:hover { color: var(--ochre); }
      .brand-mark {
        font-family: var(--font-display);
        font-size: 2.2rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: -0.04em;
        font-variation-settings: "SOFT" 20, "WONK" 1, "opsz" 144;
      }
      .brand-mark i {
        color: var(--terracotta);
        font-style: italic;
        font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
      }
      .brand-sub {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--muted);
        margin-top: 0.3rem;
      }
      .badge-slot { margin-left: auto; align-self: center; }

      .primary-nav {
        border-top: 1px solid var(--espresso-500);
        margin-top: 0.75rem;
      }
      .paper .primary-nav { border-top-color: var(--rule-soft); }
      .nav-inner {
        max-width: 76rem;
        margin: 0 auto;
        padding: 0.6rem 1.5rem;
        display: flex;
        gap: 2rem;
        font-family: var(--font-sans);
        overflow-x: auto;
        scrollbar-width: none;
      }
      .nav-inner::-webkit-scrollbar { display: none; }
      .nav-inner a {
        color: var(--paper);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        white-space: nowrap;
        padding: 0.2rem 0;
        border-bottom: 2px solid transparent;
        transition: border-color var(--transition), color var(--transition);
      }
      .paper .nav-inner a { color: var(--ink); }
      .nav-inner a:hover {
        border-bottom-color: var(--ochre);
        color: var(--ochre);
      }
      .nav-inner .num {
        font-family: var(--font-display);
        color: var(--terracotta);
        font-size: 0.75rem;
        margin-right: 0.35rem;
        font-feature-settings: "tnum" 1;
        font-variation-settings: "SOFT" 50, "WONK" 1, "opsz" 72;
      }
      .nav-inner .search-link { margin-left: auto; color: var(--ochre); }

      .banner-wrap {
        max-width: 76rem;
        margin: 1.5rem auto 0;
        padding: 0 1.5rem;
      }

      main {
        max-width: 76rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 5rem;
      }
      .paper main { background: var(--paper); }

      .site-footer {
        border-top: 1px solid var(--espresso-500);
        background: var(--espresso-700);
        font-family: var(--font-sans);
        color: var(--paper);
        margin-top: 4rem;
      }
      .paper .site-footer {
        background: var(--espresso);
        color: var(--paper);
        border-top: none;
      }
      .ft-inner {
        max-width: 76rem;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
      }
      .ft-col { display: flex; flex-direction: column; gap: 0.4rem; }
      .ft-col a { color: var(--ochre); }
      .ft-brand {
        font-family: var(--font-display);
        font-size: 1.6rem;
        letter-spacing: -0.03em;
        margin: 0;
        font-variation-settings: "SOFT" 20, "WONK" 1, "opsz" 144;
      }
      .ft-brand i { color: var(--terracotta); font-style: italic; }
      .ft-tagline { font-size: 0.9rem; color: var(--muted); margin: 0; }
      .ft-col p { margin: 0; font-size: 0.9rem; line-height: 1.5; }
      .ft-col .eyebrow { color: var(--ochre); margin-bottom: 0.4rem; }
      .ft-rule {
        max-width: 76rem;
        margin: 0 auto;
        border-top: 1px solid var(--espresso-500);
      }
      .ft-copy {
        max-width: 76rem;
        margin: 0 auto;
        padding: 1rem 1.5rem 2rem;
        font-size: 0.78rem;
        color: var(--muted);
      }

      @media (max-width: 720px) {
        .ft-inner { grid-template-columns: 1fr; gap: 2rem; }
        .nav-inner { gap: 1rem; font-size: 0.85rem; }
        .brand-sub { font-size: 0.65rem; }
      }
    </style>

    <script>
      import '../islands/profilePicker.client.ts';
      import '../islands/profileFilter.client.ts';
    </script>
  </body>
</html>
